{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./schema.json",
  "title": "michaelmace.dev feed data",
  "description": "Static feed/logbook data for /feed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "items"
  ],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/item"
      }
    }
  },
  "$defs": {
    "safeHref": {
      "type": "string",
      "pattern": "^(https?://|/|\\./|\\.\\./).+"
    },
    "relatedLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "url": {
          "$ref": "#/$defs/safeHref"
        }
      }
    },
    "embed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "url"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "youtube"
          ]
        },
        "url": {
          "$ref": "#/$defs/safeHref"
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "date"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "title": {
          "type": "string"
        },
        "body_md": {
          "type": "string"
        },
        "source_url": {
          "$ref": "#/$defs/safeHref"
        },
        "embed": {
          "$ref": "#/$defs/embed"
        },
        "image_url": {
          "$ref": "#/$defs/safeHref"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "related_links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relatedLink"
          }
        }
      },
      "anyOf": [
        {
          "required": [
            "title"
          ]
        },
        {
          "required": [
            "body_md"
          ]
        },
        {
          "required": [
            "source_url"
          ]
        },
        {
          "required": [
            "embed"
          ]
        },
        {
          "required": [
            "image_url"
          ]
        },
        {
          "required": [
            "related_links"
          ]
        }
      ]
    }
  }
}
