{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.michaelmace.dev" }],
      "destination": "https://michaelmace.dev/:path*",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:path+/index.html",
      "destination": "/:path+/",
      "permanent": true
    }
  ]
}
